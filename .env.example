# === REQUIRED: Admin access ===
RAZE_ADMIN_KEY=change-this-to-a-strong-random-string

# === REQUIRED: Google OAuth2 ===
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://yourdomain.railway.app/auth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.railway.app/auth

# === REQUIRED in production: CORS ===
# Set to your exact frontend origin (no trailing slash).
# If left empty the server defaults to blocking cross-origin requests.
RAZE_CORS_ORIGIN=https://yourdomain.railway.app

# === AUTO-INJECTED by Railway (do not set manually in Railway dashboard) ===
# Railway injects these when PostgreSQL and Redis services are linked.
DATABASE_URL=postgresql://user:password@host:5432/database
REDIS_URL=redis://default:password@host:6379

# === OPTIONAL: Default provider key ===
# Fallback key used when a model config references RAZE_PROVIDER_KEY.
# Per-model keys are stored more securely via the Admin > Routing panel.
RAZE_PROVIDER_KEY=

# === OPTIONAL: Server tuning ===
# PORT is auto-injected by Railway. Only set locally.
# PORT=3000
# RAZE_RATE_LIMIT_PER_MINUTE=60
# RAZE_TOKEN_LIMIT_PER_MINUTE=200000
# RAZE_MAX_BODY_BYTES=1000000
# RAZE_DATA_DIR=.data

# === OPTIONAL: Cache ===
# RAZE_CACHE_ENABLED=true
# RAZE_CACHE_NAMESPACE=raze:cache

# === OPTIONAL: Observability ===
# RAZE_ENABLE_METRICS=true
# LOG_LEVEL=info
